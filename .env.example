# Copy this file to ".env" in the same folder and fill in your real key.
#
#     copy .env.example .env
#
# .env is listed in .gitignore, so it never gets committed. This template is
# safe to commit precisely because it contains no real values.
#
# Get a Gemini key from Google AI Studio: https://aistudio.google.com/apikey
# Used by ai_model/llm_fallback.py to escalate low-confidence predictions.
# Without it the app still runs - it just keeps the local model's prediction
# instead of asking for a second opinion.

GEMINI_API_KEY=paste_your_key_here
